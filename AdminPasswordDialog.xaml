<!-- ====================================================================
     SafeExamBrowser - Admin Password Dialog (XAML)
     
     A custom WPF dialog for the admin exit password prompt.
     Uses a PasswordBox (masked input) instead of a plain TextBox
     to prevent shoulder-surfing by students.
     
     Styled to match the kiosk's dark theme.
     ==================================================================== -->
<Window x:Class="SafeExamBrowser.AdminPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Authentication"
        Width="420"
        Height="230"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#1a1a2e"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="🔐 Admin Authentication Required"
                   Foreground="#e94560"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- Instructions -->
        <TextBlock Grid.Row="1"
                   Text="Enter the administrator password to exit the Safe Exam Browser. This action will be logged."
                   Foreground="#8899aa"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Password field -->
        <PasswordBox x:Name="PasswordField"
                     Grid.Row="2"
                     Height="36"
                     FontSize="14"
                     Padding="8,6"
                     Background="#2a2a4a"
                     Foreground="White"
                     BorderBrush="#e94560"
                     BorderThickness="1"
                     MaxLength="50"
                     KeyDown="PasswordField_KeyDown"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#2a2a4a"
                    Foreground="#8899aa"
                    BorderBrush="#3a3a5a"
                    Click="CancelButton_Click"
                    Cursor="Hand"/>
            <Button Content="Unlock Exit"
                    Width="100"
                    Height="32"
                    Background="#e94560"
                    Foreground="White"
                    BorderBrush="#e94560"
                    FontWeight="Bold"
                    Click="UnlockButton_Click"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
