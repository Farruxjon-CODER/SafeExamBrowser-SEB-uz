<!-- ====================================================================
     SafeExamBrowser — SetupWindow.xaml (Pre-boot Session Password)
     
     SECURITY DESIGN:
     - This window is shown BEFORE any lockdown services activate.
     - The teacher creates a one-time exit password for the session.
     - Two PasswordBox controls (enter + confirm) prevent typos.
     - Clicking "Lock & Start Exam" stores the password in RAM via
       SessionManager, then hands off to MainWindow for full lockdown.
     
     UI NOTES:
     - Topmost="False" — OS is NOT locked yet; no need to steal focus.
     - ResizeMode="NoResize" — Clean, fixed-size dialog.
     - WindowStartupLocation="CenterScreen" — Always centered.
     - SizeToContent="Height" — Window auto-expands to fit all content.
     - Styled to match the kiosk's dark theme (#1a1a2e / #e94560).
     ==================================================================== -->
<Window x:Class="SafeExamBrowser.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safe Exam Browser — Session Setup"
        Width="500"
        SizeToContent="Height"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        ShowInTaskbar="True">

    <Grid Margin="32,32,32,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Icon + Title -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Description -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Password label -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: Password field -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Confirm label -->
            <RowDefinition Height="Auto"/>  <!-- Row 5: Confirm field -->
            <RowDefinition Height="Auto"/>  <!-- Row 6: Validation message -->
            <RowDefinition Height="Auto"/>  <!-- Row 7: Action buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ──────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="🔒 Safe Exam Browser — Session Setup"
                   Foreground="#e94560"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- ── Row 1: Instructions ────────────────────────────────── -->
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="#8899aa"
                   FontSize="13"
                   Margin="0,0,0,20">
            <Run Text="Create a one-time exit password for this exam session. "/>
            <Run Text="This password will be required to unlock and exit the browser. "/>
            <Run Text="It is stored in RAM only and is never saved to disk."/>
        </TextBlock>

        <!-- ── Row 2-3: Password Entry ────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   Text="Session Password"
                   Foreground="#ccddee"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <PasswordBox x:Name="PasswordField"
                     Grid.Row="3"
                     Height="38"
                     FontSize="14"
                     Padding="8,6"
                     Background="#2a2a4a"
                     Foreground="White"
                     BorderBrush="#3a3a5a"
                     BorderThickness="1"
                     MaxLength="64"
                     PasswordChanged="PasswordField_PasswordChanged"/>

        <!-- ── Row 4-5: Confirm Password ──────────────────────────── -->
        <TextBlock Grid.Row="4"
                   Text="Confirm Password"
                   Foreground="#ccddee"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,12,0,4"/>

        <PasswordBox x:Name="ConfirmPasswordField"
                     Grid.Row="5"
                     Height="38"
                     FontSize="14"
                     Padding="8,6"
                     Background="#2a2a4a"
                     Foreground="White"
                     BorderBrush="#3a3a5a"
                     BorderThickness="1"
                     MaxLength="64"
                     PasswordChanged="PasswordField_PasswordChanged"/>

        <!-- ── Row 6: Validation Feedback ─────────────────────────── -->
        <TextBlock x:Name="ValidationMessage"
                   Grid.Row="6"
                   Text=""
                   Foreground="#e94560"
                   FontSize="12"
                   Margin="0,8,0,0"/>

        <!-- ── Row 7: Action Buttons ──────────────────────────────── -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,20">

            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="110"
                    Height="42"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#2a2a4a"
                    Foreground="#ccddee"
                    BorderBrush="#3a3a5a"
                    BorderThickness="1"
                    Cursor="Hand"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"/>

            <Button x:Name="LockButton"
                    Content="🔐  Lock &amp; Start Exam"
                    Width="200"
                    Height="42"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#e94560"
                    Foreground="White"
                    BorderBrush="#e94560"
                    BorderThickness="1"
                    Cursor="Hand"
                    IsEnabled="False"
                    Click="LockButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
