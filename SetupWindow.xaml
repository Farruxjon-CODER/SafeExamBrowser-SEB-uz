<!-- ====================================================================
     SafeExamBrowser — SetupWindow.xaml (Pre-boot Session Setup)
     
     SECURITY DESIGN:
     - This window is shown BEFORE any lockdown services activate.
     - The teacher provides the exam URL and a one-time exit password.
     - Two PasswordBox controls (enter + confirm) prevent typos.
     - Clicking "Lock & Start Exam" stores both in RAM via
       SessionManager, then hands off to MainWindow for full lockdown.
     
     UI NOTES:
     - Topmost="False" — OS is NOT locked yet; no need to steal focus.
     - ResizeMode="NoResize" — Clean, fixed-size dialog.
     - WindowStartupLocation="CenterScreen" — Always centered.
     - SizeToContent="Height" — Window auto-expands to fit all content.
     - Styled to match the kiosk's dark theme (#1a1a2e / #e94560).
     ==================================================================== -->
<Window x:Class="SafeExamBrowser.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xavfsiz imtihon brauzeri — Sessiya sozlamalari"
        Width="520"
        SizeToContent="Height"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        ShowInTaskbar="True">

    <Grid Margin="32,32,32,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0:  Title -->
            <RowDefinition Height="Auto"/>  <!-- Row 1:  Description -->
            <RowDefinition Height="Auto"/>  <!-- Row 2:  Exam URL label -->
            <RowDefinition Height="Auto"/>  <!-- Row 3:  Exam URL field -->
            <RowDefinition Height="Auto"/>  <!-- Row 4:  Separator -->
            <RowDefinition Height="Auto"/>  <!-- Row 5:  Password label -->
            <RowDefinition Height="Auto"/>  <!-- Row 6:  Password field -->
            <RowDefinition Height="Auto"/>  <!-- Row 7:  Confirm label -->
            <RowDefinition Height="Auto"/>  <!-- Row 8:  Confirm field -->
            <RowDefinition Height="Auto"/>  <!-- Row 9:  Validation message -->
            <RowDefinition Height="Auto"/>  <!-- Row 10: Action buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ──────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="🔒 Xavfsiz imtihon brauzeri — Sessiya sozlamalari"
                   Foreground="#e94560"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- ── Row 1: Instructions ────────────────────────────────── -->
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="#8899aa"
                   FontSize="13"
                   Margin="0,0,0,20">
            <Run Text="Imtihon platformasi URL manzilini kiriting va bir martalik chiqish parolini yarating. "/>
            <Run Text="Parol brauzerni qulfdan chiqarish va yopish uchun talab qilinadi. "/>
            <Run Text="Barcha ma'lumotlar faqat operativ xotirada saqlanadi va diskka yozilmaydi."/>
        </TextBlock>

        <!-- ── Row 2-3: Exam URL Entry ────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   Text="Imtihon URL manzili"
                   Foreground="#ccddee"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <TextBox x:Name="UrlTextBox"
                 Grid.Row="3"
                 Height="38"
                 FontSize="14"
                 Padding="8,6"
                 Background="#2a2a4a"
                 Foreground="White"
                 BorderBrush="#3a3a5a"
                 BorderThickness="1"
                 CaretBrush="White"
                 MaxLength="2048"
                 ToolTip="To'liq imtihon URL manzilini kiriting (masalan, https://exam.example.com yoki localhost:3000)"
                 TextChanged="UrlTextBox_TextChanged"/>

        <!-- Placeholder hint below the URL field -->
        <TextBlock Grid.Row="3"
                   Text="masalan, https://exam.example.com yoki localhost:3000"
                   Foreground="#556677"
                   FontSize="11"
                   IsHitTestVisible="False"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   x:Name="UrlPlaceholder"/>

        <!-- ── Row 4: Visual Separator ────────────────────────────── -->
        <Border Grid.Row="4"
                Height="1"
                Background="#2a2a4a"
                Margin="0,16,0,12"/>

        <!-- ── Row 5-6: Password Entry ────────────────────────────── -->
        <TextBlock Grid.Row="5"
                   Text="Sessiya chiqish paroli"
                   Foreground="#ccddee"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <PasswordBox x:Name="PasswordField"
                     Grid.Row="6"
                     Height="38"
                     FontSize="14"
                     Padding="8,6"
                     Background="#2a2a4a"
                     Foreground="White"
                     BorderBrush="#3a3a5a"
                     BorderThickness="1"
                     MaxLength="64"
                     PasswordChanged="PasswordField_PasswordChanged"/>

        <!-- ── Row 7-8: Confirm Password ──────────────────────────── -->
        <TextBlock Grid.Row="7"
                   Text="Parolni tasdiqlang"
                   Foreground="#ccddee"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,12,0,4"/>

        <PasswordBox x:Name="ConfirmPasswordField"
                     Grid.Row="8"
                     Height="38"
                     FontSize="14"
                     Padding="8,6"
                     Background="#2a2a4a"
                     Foreground="White"
                     BorderBrush="#3a3a5a"
                     BorderThickness="1"
                     MaxLength="64"
                     PasswordChanged="PasswordField_PasswordChanged"/>

        <!-- ── Row 9: Validation Feedback ─────────────────────────── -->
        <TextBlock x:Name="ValidationMessage"
                   Grid.Row="9"
                   Text=""
                   Foreground="#e94560"
                   FontSize="12"
                   Margin="0,8,0,0"/>

        <!-- ── Row 10: Action Buttons ─────────────────────────────── -->
        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,20">

            <Button x:Name="CancelButton"
                    Content="Bekor qilish"
                    Width="110"
                    Height="42"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#2a2a4a"
                    Foreground="#ccddee"
                    BorderBrush="#3a3a5a"
                    BorderThickness="1"
                    Cursor="Hand"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"/>

            <Button x:Name="LockButton"
                    Content="🔐  Qulflash &amp; Imtihonni boshlash"
                    Width="200"
                    Height="42"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#e94560"
                    Foreground="White"
                    BorderBrush="#e94560"
                    BorderThickness="1"
                    Cursor="Hand"
                    IsEnabled="False"
                    Click="LockButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
