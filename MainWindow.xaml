<!-- ====================================================================
     SafeExamBrowser - Stage 1: Kiosk Window (XAML)
     
     SECURITY DESIGN:
     - WindowStyle="None"       → No title bar, no close/min/max buttons
     - WindowState="Maximized"  → Full-screen coverage
     - Topmost="True"           → Stays above all other windows
     - ResizeMode="NoResize"    → Cannot be resized or moved
     - ShowInTaskbar="False"    → Hidden from taskbar (no right-click close)
     - Background="Black"       → No white flash on startup
     ==================================================================== -->
<Window x:Class="SafeExamBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Xavfsiz imtihon brauzeri"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Black"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- Main layout: WebView2 fills the entire window -->
    <Grid>
        <!-- Loading overlay - shown while WebView2 initializes -->
        <Border x:Name="LoadingOverlay"
                Background="#1a1a2e"
                Panel.ZIndex="10"
                Visibility="Visible">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="🔒 Xavfsiz imtihon brauzeri"
                           Foreground="#e94560"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Xavfsiz muhit ishga tushirilmoqda..."
                           Foreground="#8899aa"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="4"
                             Foreground="#e94560"
                             Background="#2a2a4a"/>
            </StackPanel>
        </Border>

        <!-- WebView2 browser control - fills the entire screen -->
        <wv2:WebView2 x:Name="ExamWebView"
                      Panel.ZIndex="1"/>
    </Grid>
</Window>
